VITE_GENERATED_APP_URL=
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=
VITE_SOLANA_RPC_URL=

# Set on the Convex deployment (npx convex env set ...)
# Clerk Frontend API URL, e.g. https://verb-noun-00.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# --- App generation backend (Convex dashboard / `npx convex env set`) ---
# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_STARTER_REPO=gc-m1kael/solbuilder-app-starter

# Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Convex Platform (Management API) for generated-app projects
CONVEX_TEAM_TOKEN=
CONVEX_TEAM_ID=
# Optional label only; Management API requires CONVEX_TEAM_ID
CONVEX_TEAM_SLUG=

# Cursor Background Agents
CURSOR_API_KEY=
# Optional HMAC/shared secret for /cursor-webhook
CURSOR_WEBHOOK_SECRET=

# Host site URL used for webhooks / generated-app host env
CONVEX_SITE_URL=

# Explicit non-production mode: adapters refuse to provision (never fakes success)
# SOLBUILDER_ADAPTER_MODE=stub
